rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function belongsToFamily(familyId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    function isParentInFamily(familyId) {
      return belongsToFamily(familyId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isParent == true;
    }

    // Admin helper - checks for admin custom claim in auth token
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Validation helper - checks if a field is being incremented by at most maxIncrement
    function isValidIncrement(field, maxIncrement) {
      return request.resource.data[field] <= resource.data[field] + maxIncrement;
    }

    // Validation helper - checks if a field is unchanged
    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // Validation helper - checks if stats update is valid (prevents manipulation)
    function isValidStatsUpdate() {
      // Stars can only increase by max 100 per operation (5 prayers * 10 stars + bonus)
      let validStars = !('stars' in request.resource.data) ||
        request.resource.data.stars <= resource.data.stars + 100;

      // Total prayers can only increase by max 5 per operation (5 daily prayers)
      let validPrayers = !('totalPrayers' in request.resource.data) ||
        request.resource.data.totalPrayers <= resource.data.totalPrayers + 5;

      // Streak can only increase by 1 or reset to 0-1
      let validStreak = !('currentStreak' in request.resource.data) ||
        request.resource.data.currentStreak <= resource.data.currentStreak + 1 ||
        request.resource.data.currentStreak <= 1;

      // Cannot decrease values (except streak reset)
      let noDecrease =
        (!('stars' in request.resource.data) || request.resource.data.stars >= resource.data.stars) &&
        (!('totalPrayers' in request.resource.data) || request.resource.data.totalPrayers >= resource.data.totalPrayers);

      return validStars && validPrayers && validStreak && noDecrease;
    }

    // Users collection - users can only read/write their own document
    // Leaderboard: allow reading limited fields (name, stars) for all authenticated users
    // Issue #12: Added validation to prevent stat manipulation
    // Issue #31: Admins can read all users for user management
    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow reading for leaderboard + admin
      allow create: if isOwner(userId);
      // Update requires ownership AND valid stat changes (prevents manipulation)
      allow update: if isOwner(userId) && isValidStatsUpdate();
      allow delete: if false; // Users cannot delete their accounts directly

      // User's prayer subcollection
      match /prayers/{date} {
        allow read, write: if isOwner(userId);
      }

      // User's progress subcollection
      match /progress/{docId} {
        allow read, write: if isOwner(userId);
      }

      // User's task completions subcollection (Issue #26)
      // P1-5: Enforce one completion per task per day via document ID format {taskId}_{date}
      match /taskCompletions/{completionId} {
        allow read: if isOwner(userId);
        // Users can create completions for themselves, with these constraints:
        // 1. User ID must match authenticated user
        // 2. Document ID must match format: {taskId}_{completedDate}
        // 3. Required fields must be present
        // 4. starsEarned must be a positive number <= 100 (prevent manipulation)
        allow create: if isOwner(userId) &&
          request.resource.data.userId == request.auth.uid &&
          request.resource.data.taskId is string &&
          request.resource.data.completedDate is string &&
          request.resource.data.starsEarned is number &&
          request.resource.data.starsEarned > 0 &&
          request.resource.data.starsEarned <= 100 &&
          // Verify document ID matches the expected format: taskId_date
          completionId == request.resource.data.taskId + '_' + request.resource.data.completedDate;
        allow update: if false; // No updates allowed - completions are immutable
        allow delete: if false;
      }
    }

    // Families collection - only family members can access
    // Issue #31: Admins can read all families for user management
    match /families/{familyId} {
      allow read: if belongsToFamily(familyId) || isAdmin();
      allow create: if isAuthenticated(); // Any authenticated user can create a family
      allow update: if isParentInFamily(familyId);
      allow delete: if false; // Families cannot be deleted

      // Children subcollection - parents can manage, children can read their own
      match /children/{childId} {
        allow read: if belongsToFamily(familyId);
        allow create: if isParentInFamily(familyId);
        allow update: if isParentInFamily(familyId);
        allow delete: if isParentInFamily(familyId);
      }
    }

    // Prayer records - users can only access their own
    match /prayers/{odcId} {
      // Document ID format: {userId}_{date}
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Stats collection - users can only access their own
    // Issue #12: Added validation to prevent stat manipulation
    match /stats/{userId} {
      allow read: if isOwner(userId) ||
        // Allow family members to read for leaderboard
        belongsToFamily(resource.data.familyId);
      allow create: if isOwner(userId);
      // Update requires ownership AND valid stat changes (prevents manipulation)
      allow update: if isOwner(userId) && isValidStatsUpdate();
      allow delete: if false;
    }

    // Story progress - users can only access their own
    match /storyProgress/{odcId} {
      // Document ID format: {userId}_{storyDay}
      allow read: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() &&
        resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // Stories collection (Issue #25) - admin can write, all users can read
    match /stories/{storyId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Bonus Tasks collection (Issue #26) - admin can write, all users can read
    match /bonusTasks/{taskId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Admin Audit Logs collection (Issue #31) - admin can read/create, immutable
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false; // Audit trail is immutable
    }

    // Leaderboard - read-only for family members
    match /leaderboard/{familyId} {
      allow read: if belongsToFamily(familyId);
      allow write: if false; // Updated via Cloud Functions only

      match /entries/{entryId} {
        allow read: if belongsToFamily(familyId);
        allow write: if false;
      }
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
